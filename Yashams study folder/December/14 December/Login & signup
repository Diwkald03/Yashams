def reset_password(token, new_password):
    with sqlite3.connect('users.db') as conn:
        cur = conn.cursor()
        cur.execute("""
            SELECT username FROM password_resets 
            WHERE token=? AND expires_at > datetime('now')
        """, (token,))
        result = cur.fetchone()
        
        if result:
            # Update password
            pwd_hash = bcrypt.hashpw(new_password.encode(), bcrypt.gensalt())
            cur.execute("UPDATE users SET password_hash=? WHERE username=?",
                       (pwd_hash, result[0]))
            
            # Cleanup expired token
            cur.execute("DELETE FROM password_resets WHERE token=?", (token,))
            conn.commit()
            return True
        return False

