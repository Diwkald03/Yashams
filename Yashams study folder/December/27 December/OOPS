Streamlit HR System OOP Architecture

python
class Employee:
    employee_count = 0  # Class variable
    
    def __init__(self, name, salary):
        self.name = name
        self.__salary = salary  # Encapsulated
        Employee.employee_count += 1
    
    def get_salary(self):  # Abstraction
        return self.__salary

class Developer(Employee):
    def code(self):  # Polymorphism
        return f"{self.name} writes Python"

class HRSystem:  # Encapsulation
    def __init__(self):
        self.employees = []
    
    def add_employee(self, emp):  # Interface
        self.employees.append(emp)

