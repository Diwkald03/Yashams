5. How would you secure CRUD operations in production?

Enterprise-grade security checklist:

python
import hashlib, secrets
from datetime import datetime

# === 1. INPUT SANITIZATION ===
def safe_insert(name, email, salary):
    # SQL injection prevention (parameterized queries)
    with get_cursor() as cur:
        cur.execute(
            "INSERT INTO employees (name, email, salary, created_at) VALUES (?, ?, ?, ?)",
            (name.strip(), email.lower(), float(salary), datetime.now())
        )

# === 2. AUTHENTICATION ===
def authenticate_user(username, password):
    pwd_hash = hashlib.pbkdf2_hash(password.encode(), salt=secrets.token_bytes(16))
    with get_cursor() as cur:
        cur.execute("SELECT role FROM users WHERE username=? AND pwd_hash=?", 
                   (username, pwd_hash))
        return cur.fetchone()

# === 3. AUTHORIZATION (RBAC) ===
def require_role(role):
    user_role = st.session_state.get('user_role')
    if user_role != role:
        st.error(f"Admin access required")
        st.stop()

# === 4. AUDIT TRAIL ===
def log_action(user_id, action, table, record_id):
    with get_cursor() as cur:
        cur.execute("INSERT INTO audit_log (user_id, action, table_name, record_id, timestamp) VALUES (?, ?, ?, ?, ?)",
                   (user_id, action, table, record_id, datetime.now()))

# === PRODUCTION CRUD APP ===
if st.sidebar.button("Admin Panel") and st.session_state.get('is_admin'):
    require_role('admin')
    
    with st.form("add_employee"):
        name = st._input("Name")
        salary = st.number_input("Salary ₹L")
        if st.form_submit_button("Add Employee"):
            safe_insert(name, salary)
            log_action(st.session_state.user_id, 'CREATE', 'employees', 'NEW')
            st.success("Employee added!")

Security Hardening:


🔒 Parameterized queries (no SQL injection)
🛡️ Role-Based Access Control (RBAC)
📝 Audit logging (compliance)
🔑 Password hashing (PBKDF2)
⚠️  Input validation (type + range)
⏱️ Connection pooling (@st.cache_resource)

Complete Production CRUD Example

python
# File: crud_app.py
import streamlit as st
import sqlite3, pandas as pd

# Initialize DB
@st.cache_resource
def init_db():
    conn = sqlite3.connect('employees.db')
    conn.execute('''CREATE TABLE IF NOT EXISTS employees
                 (id INTEGER PRIMARY KEY, name , salary REAL, dept )''')
    return conn

# CRUD OPERATIONS
def create_employee(name, salary, dept):
    with get_cursor() as cur:
        cur.execute("INSERT INTO employees (name, salary, dept) VALUES (?, ?, ?)",
                   (name, salary, dept))

def read_employees():
    with get_cursor() as cur:
        cur.execute("SELECT * FROM employees")
        return pd.DataFrame(cur.fetchall(), columns=['id','name','salary','dept'])

# MAIN APP
st.title("👥 Employee Management")
df = read_employees()

# Add new employee (CREATE)
with st.form("add_employee"):
    col1, col2 = st.columns(2)
    name = col1._input("Name")
    salary = col2.number_input("Salary")
    dept = st.selectbox("Department", ['Engineering', 'Marketing', 'HR'])
    if st.form_submit_button("Add"):
        create_employee(name, salary, dept)
        st.rerun()

st.dataframe(df)  # READ

