Production Implementation Template

python
def production_split(X, y, test_size=0.20, random_state=42, stratify=None):
    """Enterprise-grade train-test split"""
    X_train, X_test, y_train, y_test = train_test_split(
        X, y,
        test_size=test_size,
        random_state=random_state,
        stratify=stratify
    )
    
    print(f"✅ Train: {len(X_train):,}/{len(X):,} ({100*(1-test_size):.0f}%)")
    print(f"✅ Test:  {len(X_test):,} ({100*test_size:.0f}%)")
    
    # Balance verification
    if stratify is not None:
        print("Class balance preserved ✓")
    
    return X_train, X_test, y_train, y_test

# Usage
X_train, X_test, y_train, y_test = production_split(X_salary, y_salary)

