5. How would you read each uploaded file inside a loop?

Production-grade loop with error handling + progress tracking:

python
@st.cache_data
def process_all_files(uploaded_files):
    """Batch process multiple files with error handling"""
    results = []
    
    progress_bar = st.progress(0)
    status_text = st.empty()
    
    for idx, uploaded_file in enumerate(uploaded_files):
        try:
            status_text.text(f"Processing {uploaded_file.name}...")
            
            # Type detection + loading
            if uploaded_file.name.endswith('.csv'):
                df = pd.read_csv(uploaded_file)
            else:
                df = pd.read_excel(uploaded_file)
            
            # Basic data profiling
            profile = {
                'filename': uploaded_file.name,
                'rows': len(df),
                'columns': len(df.columns),
                'missing': df.isnull().sum().sum(),
                'memory_mb': df.memory_usage(deep=True).sum() / 1024**2
            }
            
            results.append((df, profile))
            progress_bar.progress((idx + 1) / len(uploaded_files))
            
        except Exception as e:
            st.error(f"❌ Failed to process {uploaded_file.name}: {str(e)}")
            continue
    
    status_text.text(f"✅ Processed {len(results)}/{len(uploaded_files)} files")
    return results

# Execute processing
if uploaded_files:
    processed_data = process_all_files(uploaded_files)
    
    # Summary table
    summary_df = pd.DataFrame([p for _, p in processed_data])
    st.dataframe(summary_df)
    
    # Combined analysis
    if len(processed_data) > 1:
        combined_df = pd.concat([df for df, _ in processed_data], 
                               keys=[p['filename'] for _, p in processed_data],
                               names=['file', 'index'])
        st.subheader("Combined Dataset")
        st.dataframe(combined_df)

