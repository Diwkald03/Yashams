Advanced Production Patterns

bash
# 1. Poetry/Pipenv (Next-gen dependency management)
poetry init
poetry add streamlit pandas
poetry shell  # Auto-manages venv

# 2. Docker Integration
FROM python:3.11-slim
COPY requirements.txt .
RUN python -m venv /opt/venv && \
    /opt/venv/bin/pip install -r requirements.txt
ENV PATH="/opt/venv/bin:$PATH"

# 3. GitHub Codespaces (.devcontainer)
"postCreateCommand": "python -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt"

